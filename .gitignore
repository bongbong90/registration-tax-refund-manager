# Python
__pycache__/
*.py[cod]

# Virtual env
.venv/
venv/

# Local DB and case data
data/refund.db
data/cases/*
!data/cases/.gitkeep
data/backup/*
!data/backup/.gitkeep
data/hwp_test_output/

# Sensitive office config
config/office_info.json
config/office_info.lock

# Logs
logs/*
